# Root scripts (notion/*.js one-off setup scripts) — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys.

# Notion internal integration token — https://www.notion.so/my-integrations
NOTION_KEY=ntn_your_notion_integration_token

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_KEY=sk-ant-your_anthropic_api_key

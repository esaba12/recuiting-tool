# Single .env at the repo root — copy to `.env` and fill in. Read by:
#   - app/vite.config.js (dev server + serverless function shims), via loadEnv
#     pointed at this directory
#   - app/api/*.js (Vercel serverless functions in production — same vars,
#     set as encrypted Vercel env vars instead of a committed file)
#   - scripts/*.js (one-off Notion setup scripts, the Notion->Supabase migration)
# `.env` is gitignored; never commit real keys.

# ── Supabase (auth + multi-tenant Postgres) ─────────────────────────────────
# Local dev: run `supabase start` (repo root) and paste its printed values below —
# every local stack uses the same well-known demo JWT signing secret, so these
# anon/service_role tokens are identical across machines for local dev.
# Production: create a project at https://supabase.com, then Project Settings → API.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
# Server-only — NEVER prefix with VITE_ (Vite inlines VITE_* vars into the browser bundle).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Server-only master key (32-byte hex) for AES-256-GCM encryption of BYOK API keys and
# Google Calendar refresh tokens before they're stored in Postgres (user_api_keys,
# google_calendar_tokens — neither table has RLS policies, so the browser can never read
# them directly even with a valid session; only server code with this key can decrypt).
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SECRET_ENCRYPTION_KEY=

# ── Google Calendar OAuth app (shared client, per-user consent) ────────────
# One OAuth app/client for the whole deployment — each user's own refresh token (captured
# via Settings -> "Connect Calendar") is what's actually per-user, stored encrypted in
# google_calendar_tokens. Setup: Google Cloud Console -> enable Calendar API -> OAuth
# consent screen (External) -> Credentials -> OAuth Client ID (type "Web application",
# add your dev + prod URLs as authorized redirect URIs).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Notion (legacy single-tenant setup scripts + one-time migration only) ──
# NOT used by the deployed app anymore (db.js talks to Supabase directly) — only by
# notion/*.js one-off setup scripts and scripts/migrate-notion-to-supabase.js, for
# migrating an existing personal Notion workspace's data into a Supabase account once.
NOTION_API_KEY=ntn_your_notion_integration_token
CONTACTS_DB_ID=
CALLS_DB_ID=
APPS_DB_ID=
LC_DB_ID=
INTERACTIONS_DB_ID=

# ── Everything below is now BYOK (Settings tab, per signed-in user) ────────
# ANTHROPIC_API_KEY / OPENAI_API_KEY / EXA_API_KEY / GITHUB_TOKEN are no longer read
# from env by the deployed app — every user adds their own in Settings, encrypted
# per-user in user_api_keys. Nothing to set here for a fresh multi-tenant deploy.

# Dashboard (app/) — copy to `.env.local` and fill in.
# `.env.local` is gitignored. These are read server-side by the Vite dev proxy
# (vite.config.js) and by the Vercel serverless functions (api/*.js). They are
# NEVER exposed to the browser bundle.

# Notion internal integration token, shared with your databases
NOTION_API_KEY=ntn_your_notion_integration_token

# Anthropic API key (used for fit analysis, call/email/LinkedIn extraction)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional — raises GitHub API rate limits for the Job Boards parser
GITHUB_TOKEN=

# Google Calendar (screenshot/text → calendar event feature). One-time setup:
# 1. Google Cloud Console → create/reuse a project → enable the Calendar API
# 2. OAuth consent screen: External + Testing (single-user, no review needed)
# 3. Credentials → Create OAuth Client ID → type "Desktop app" → gives you the two values below
# 4. Run `node google-calendar/get-refresh-token.js` once to get GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
